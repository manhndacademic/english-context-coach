# ==============================================================================
# ENGLISH CONTEXT COACH - ENVIRONMENT VARIABLES TEMPLATE
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. DATABASE CONFIGURATION
# ------------------------------------------------------------------------------

# Database connection URL for Next.js and Drizzle ORM
DATABASE_URL=postgres://postgres:postgres@localhost:5432/english_context_coach

# Database settings used by Docker Compose to provision the PostgreSQL service
DB_PASSWORD=postgres
DB_NAME=english_context_coach

# ------------------------------------------------------------------------------
# 2. REDIS & BACKGROUND QUEUE CONFIGURATION
# ------------------------------------------------------------------------------

# Redis server connection URL (required for BullMQ queue)
REDIS_URL=redis://localhost:6379

# Number of concurrent jobs processed by a single background worker
WORKER_CONCURRENCY=1

# ------------------------------------------------------------------------------
# 3. AUTHENTICATION & SECURITY
# ------------------------------------------------------------------------------

# Secret key used to encrypt and sign Auth.js (NextAuth) cookies. Generate using: `openssl rand -hex 32`
AUTH_SECRET=replace-with-a-random-secret

# The public canonical URL of your deployed application (must use HTTPS in production)
AUTH_URL=http://localhost:3000

# Set to true to trust forwarded headers from reverse proxies (Nginx, Traefik, NPM, etc.)
AUTH_TRUST_HOST=true

# Google OAuth Client Credentials for user sign-in. Get these from Google Cloud Console
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Secret key used to encrypt API Keys stored securely in the database. Generate using: `openssl rand -hex 16` (min 32 chars)
ENCRYPTION_SECRET=replace-with-a-random-secret-key-32-chars

# Primary admin email. Users logging in with this email are automatically promoted to admin
ADMIN_EMAIL=admin@example.com

# ------------------------------------------------------------------------------
# 4. AI & GEMINI CONFIGURATION
# ------------------------------------------------------------------------------

# Fallback Gemini API Key. Can be a single key, or multiple keys separated by commas/newlines with inline comments (# or //)
GEMINI_API_KEY=

# Gemini API Keys for rotation (takes precedence over GEMINI_API_KEY).
# Can be comma-separated or multi-line (each key on one line) with comments.
# Example:
# GEMINI_API_KEYS="
#   key1 # Account 1
#   key2 # Account 2
# "
# GEMINI_API_KEYS=key1,key2,key3

# Fallback Gemini models used for lesson analysis and homework grading
GEMINI_ANALYSIS_MODELS=gemini-3.1-flash-lite,gemma-4-31b-it,gemma-4-26b-a4b-it,gemini-3-flash-preview,gemini-3.5-flash

# Fallback Gemini models used for fast operations like generating review prompt questions
GEMINI_FAST_MODELS=gemini-3.1-flash-lite,gemma-4-31b-it,gemma-4-26b-a4b-it,gemini-3-flash-preview,gemini-3.5-flash

# Gemini thinking budget level (MINIMAL, LOW, MEDIUM, HIGH)
GEMINI_THINKING_LEVEL=MINIMAL

# Gemini Max Output Tokens configuration (for fine-tuning output limits per purpose)
# GEMINI_MAX_OUTPUT_TOKENS_ANALYSIS=8192
# GEMINI_MAX_OUTPUT_TOKENS_EXERCISE=2200
# GEMINI_MAX_OUTPUT_TOKENS_GRADING=700
# GEMINI_MAX_OUTPUT_TOKENS_REPAIR=1200

