DATABASE_URL=postgres://postgres:postgres@localhost:5432/english_context_coach
AUTH_SECRET=replace-with-a-random-secret
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GEMINI_API_KEY=
GEMINI_ANALYSIS_MODEL=gemini-3.1-flash-lite
GEMINI_FAST_MODEL=gemini-3.1-flash-lite
GEMINI_THINKING_LEVEL=MINIMAL
WORKER_CONCURRENCY=1

# Optional settings for Docker Compose database configuration
DB_PASSWORD=postgres
DB_NAME=english_context_coach

# Key encryption (used to encrypt global API keys stored in database)
ENCRYPTION_SECRET=replace-with-a-random-secret-key-32-chars

# Auto-promote user to admin on login
ADMIN_EMAIL=admin@example.com

